{
  "editor.formatOnSave": true,
  "biome.lsp.bin": {
    "win32-x64": "./client/node_modules/@biomejs/cli-win32-x64/biome.exe",
    "linux-x64": "./client/node_modules/@biomejs/cli-linux-x64/biome",
    "linux-arm64": "./client/node_modules/@biomejs/cli-linux-arm64/biome",
    "linux-x64-musl": "./client/node_modules/@biomejs/cli-linux-x64-musl/biome",
    "linux-arm64-musl": "./client/node_modules/@biomejs/cli-linux-arm64-musl/biome",
    "darwin-x64": "./client/node_modules/@biomejs/cli-darwin-x64/biome",
    "darwin-arm64": "./client/node_modules/@biomejs/cli-darwin-arm64/biome"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "[html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "[django-html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "[jinja]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "[jinja-html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "python.analysis.autoSearchPaths": true,
  "python.analysis.extraPaths": ["backend"],
  "python.analysis.ignore": ["**/site-packages/**/*.py", "**/migrations/*.py"],
  "python.autoComplete.extraPaths": [".venv", "backend"],
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.testing.pytestEnabled": true,
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit",
      "source.action.useSortedAttributes.biome": "explicit",
      "source.action.useSortedProperties.biome": "explicit",
      "source.action.useSortedKeys.biome": "explicit",
      "source.organizeImports.biome": "explicit",
      "source.fixAll.biome": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/mypy_cache": true,
    "**/package-lock.json": true,
    "**/uv.lock": true
  }
}
